{
  "name": "@cssdoc/dialects",
  "version": "0.3.1",
  "description": "Resolve a PostCSS parser for a stylesheet dialect (SCSS, Sass, Less) to document non-CSS sources with cssdoc.",
  "keywords": [
    "css",
    "cssdoc",
    "less",
    "postcss",
    "scss"
  ],
  "homepage": "https://cssdoc.dev",
  "bugs": "https://github.com/thedannywahl/cssdoc/issues",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thedannywahl/cssdoc.git",
    "directory": "packages/dialects"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test",
    "check": "vp check",
    "prepublishOnly": "vp run build",
    "publint": "publint"
  },
  "dependencies": {
    "postcss": "catalog:",
    "postcss-less": "^6.0.0",
    "postcss-scss": "^4.0.9"
  },
  "devDependencies": {
    "@cssdoc/core": "workspace:*",
    "@types/node": "catalog:",
    "publint": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plus": "catalog:"
  }
}
