{
  "name": "cssdoc",
  "version": "0.0.0",
  "private": true,
  "description": "TSDoc, for CSS — a Vite+ monorepo: parser, config, emitters, and lint/TypeDoc plugins.",
  "type": "module",
  "scripts": {
    "build": "vp run -r build",
    "check": "vp check",
    "test": "vp run -r test",
    "ready": "vp run -r build && vp check && vp run -r test",
    "check:publish": "pnpm -r --filter \"./packages/**\" --filter \"./emitters/**\" --filter \"./generators/**\" --filter \"./plugins/**\" --filter \"./servers/**\" --filter \"!cssdoc-vscode\" exec publint"
  },
  "devDependencies": {
    "publint": "catalog:",
    "vite": "npm:@voidzero-dev/vite-plus-core@0.2.2",
    "vite-plus": "catalog:"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.9.0",
      "onFail": "download"
    }
  },
  "engines": {
    "node": ">=22.18.0"
  }
}
