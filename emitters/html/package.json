{
  "name": "@cssdoc/html",
  "version": "0.0.0",
  "description": "Emit standalone, self-contained HTML reference pages from the cssdoc model — one page per record plus an index.",
  "keywords": [
    "css",
    "cssdoc",
    "documentation",
    "emitter",
    "html"
  ],
  "license": "MIT",
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test",
    "check": "vp check",
    "publint": "publint",
    "prepublishOnly": "vp run build"
  },
  "dependencies": {
    "@cssdoc/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "publint": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plus": "catalog:"
  }
}
