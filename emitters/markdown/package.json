{
  "name": "@cssdoc/markdown",
  "version": "0.5.4",
  "description": "Render an @cssdoc/core model to markdown reference pages + a sidebar (compatible with typedoc-plugin-markdown / typedoc-vitepress-theme).",
  "keywords": [
    "css",
    "cssdoc",
    "documentation",
    "emitter",
    "markdown"
  ],
  "homepage": "https://cssdoc.dev",
  "bugs": "https://github.com/thedannywahl/cssdoc/issues",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thedannywahl/cssdoc.git",
    "directory": "emitters/markdown"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test",
    "check": "vp check",
    "prepublishOnly": "vp run build",
    "publint": "publint"
  },
  "dependencies": {
    "@cssdoc/core": "workspace:*",
    "@cssdoc/dialects": "workspace:*",
    "@cssdoc/embedded": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "publint": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plus": "catalog:"
  }
}
