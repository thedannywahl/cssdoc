{
  "//": "Compiler options for the TypeDoc API-reference build only (not used by vp check). Mirrors the packages' settings and enables skipLibCheck so third-party .d.ts (e.g. vite-plus) don't fail the run.",
  "compilerOptions": {
    "target": "esnext",
    "lib": ["es2023"],
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "types": ["node"],
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": [
    "../packages/*/src/index.ts",
    "../emitters/*/src/index.ts",
    "../generators/*/src/index.ts",
    "../plugins/*/src/index.ts",
    "../servers/language-server/src/index.ts"
  ]
}
