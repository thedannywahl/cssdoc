{
  "$schema": "https://typedoc.org/schema.json",
  "plugin": ["typedoc-plugin-markdown", "typedoc-vitepress-theme"],
  "entryPointStrategy": "resolve",
  "entryPoints": [
    "../packages/*/src/index.ts",
    "../emitters/*/src/index.ts",
    "../generators/*/src/index.ts",
    "../plugins/*/src/index.ts",
    "../servers/language-server/src/index.ts"
  ],
  "tsconfig": "tsconfig.typedoc.json",
  "out": "reference",
  "docsRoot": ".",
  "readme": "none",
  "githubPages": false,
  "basePath": "..",
  "disableGit": true,
  "sourceLinkTemplate": "https://github.com/thedannywahl/cssdoc/blob/main/{path}#L{line}",
  "entryFileName": "index",
  "hidePageHeader": true,
  "hideBreadcrumbs": true,
  "useCodeBlocks": true
}
