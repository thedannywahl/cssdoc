{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run cssdoc extension",
      "type": "extensionHost",
      "request": "launch",
      "args": ["--extensionDevelopmentPath=${workspaceFolder}", "${workspaceFolder}/examples"],
      "outFiles": ["${workspaceFolder}/dist/**/*.cjs"],
      "preLaunchTask": "build"
    }
  ]
}
