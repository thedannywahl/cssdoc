{
  "name": "cssdoc-vscode",
  "displayName": "cssdoc",
  "version": "0.0.0",
  "private": true,
  "description": "VS Code support for cssdoc: completions, hover, go-to-definition, and deprecation quick-fixes for documented CSS classes, modifiers, and custom properties.",
  "categories": [
    "Linters",
    "Programming Languages"
  ],
  "homepage": "https://cssdoc.dev",
  "bugs": "https://github.com/thedannywahl/cssdoc/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thedannywahl/cssdoc.git",
    "directory": "servers/vscode"
  },
  "publisher": "cssdoc",
  "type": "module",
  "main": "./dist/extension.cjs",
  "scripts": {
    "build": "node scripts/build.mjs",
    "check": "vp check",
    "test": "vp test",
    "icon": "node scripts/gen-icon.mjs",
    "package": "vp run -t build && vsce package --no-dependencies -o cssdoc.vsix",
    "publish:marketplace": "vp run -t build && vsce package --no-dependencies -o cssdoc.vsix && vsce publish --no-dependencies --packagePath cssdoc.vsix && ovsx publish cssdoc.vsix"
  },
  "dependencies": {
    "@cssdoc/language-server": "workspace:*",
    "vscode-languageclient": "catalog:"
  },
  "devDependencies": {
    "@resvg/resvg-js": "catalog:",
    "@types/node": "catalog:",
    "@types/vscode": "^1.125.0",
    "@vscode/vsce": "catalog:",
    "esbuild": "catalog:",
    "ovsx": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plus": "catalog:"
  },
  "contributes": {
    "grammars": [
      {
        "scopeName": "documentation.cssdoc",
        "path": "./syntaxes/cssdoc.injection.tmLanguage.json",
        "injectTo": [
          "source.css"
        ]
      }
    ],
    "configuration": {
      "title": "cssdoc",
      "properties": {
        "cssdoc.css": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Paths to the documented CSS files the language server reads."
        }
      }
    }
  },
  "activationEvents": [
    "onLanguage:css",
    "onLanguage:html",
    "onLanguage:javascriptreact",
    "onLanguage:typescriptreact"
  ],
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.125.0"
  }
}
