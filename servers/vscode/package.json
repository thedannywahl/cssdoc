{
  "name": "@cssdoc/vscode",
  "displayName": "cssdoc",
  "version": "0.0.0",
  "private": true,
  "description": "VS Code support for cssdoc: completions, hover, go-to-definition, and deprecation quick-fixes for documented CSS classes, modifiers, and custom properties.",
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test",
    "check": "vp check"
  },
  "dependencies": {
    "@cssdoc/language-server": "workspace:*",
    "vscode-languageclient": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/vscode": "catalog:",
    "typescript": "catalog:",
    "vite": "npm:@voidzero-dev/vite-plus-core@0.2.2",
    "vite-plus": "catalog:"
  },
  "contributes": {
    "configuration": {
      "title": "cssdoc",
      "properties": {
        "cssdoc.css": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Paths to the documented CSS files the language server reads."
        }
      }
    }
  },
  "activationEvents": [
    "onLanguage:css",
    "onLanguage:html",
    "onLanguage:javascriptreact",
    "onLanguage:typescriptreact"
  ],
  "engines": {
    "vscode": "^1.125.0"
  }
}
