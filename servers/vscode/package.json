{
  "name": "cssdoc-vscode",
  "displayName": "cssdoc",
  "version": "0.3.1",
  "private": true,
  "description": "VS Code support for cssdoc: completions, hover, go-to-definition, and deprecation quick-fixes for documented CSS classes, modifiers, and custom properties.",
  "categories": [
    "Linters",
    "Programming Languages"
  ],
  "homepage": "https://cssdoc.dev",
  "bugs": "https://github.com/thedannywahl/cssdoc/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thedannywahl/cssdoc.git",
    "directory": "servers/vscode"
  },
  "publisher": "cssdoc",
  "type": "module",
  "main": "./dist/extension.cjs",
  "scripts": {
    "build": "node scripts/build.mjs",
    "check": "vp check",
    "test": "vp test",
    "icon": "node scripts/gen-icon.mjs",
    "package": "vp run -t build && vsce package --no-dependencies -o cssdoc.vsix",
    "publish:vsce": "vsce publish --no-dependencies --packagePath cssdoc.vsix",
    "publish:ovsx": "ovsx publish cssdoc.vsix"
  },
  "dependencies": {
    "@cssdoc/language-server": "workspace:*",
    "vscode-languageclient": "catalog:"
  },
  "devDependencies": {
    "@resvg/resvg-js": "catalog:",
    "@types/node": "catalog:",
    "@types/vscode": "^1.125.0",
    "@vscode/vsce": "catalog:",
    "esbuild": "catalog:",
    "ovsx": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plus": "catalog:"
  },
  "contributes": {
    "grammars": [
      {
        "scopeName": "documentation.cssdoc",
        "path": "./syntaxes/cssdoc.injection.tmLanguage.json",
        "injectTo": [
          "source.css",
          "source.scss",
          "source.less",
          "source.css.styled",
          "source.ts",
          "source.tsx",
          "source.js",
          "source.jsx",
          "source.vue",
          "source.svelte",
          "source.astro",
          "text.html.markdown",
          "text.html.basic",
          "text.html.derivative"
        ]
      }
    ],
    "jsonValidation": [
      {
        "fileMatch": [
          "cssdoc.json",
          "cssdoc.jsonc"
        ],
        "url": "./schemas/cssdoc.schema.json"
      }
    ],
    "configuration": {
      "title": "cssdoc",
      "properties": {
        "cssdoc.include": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "**/*.css"
          ],
          "markdownDescription": "Globs for the documented CSS the language server reads. Auto-detects all CSS in the workspace by default."
        },
        "cssdoc.exclude": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "**/node_modules/**"
          ],
          "markdownDescription": "Globs excluded from `#cssdoc.include#` auto-detection."
        },
        "cssdoc.css": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "markdownDescription": "Explicit paths to documented CSS files. When set, this overrides `#cssdoc.include#` / `#cssdoc.exclude#` auto-detection.",
          "markdownDeprecationMessage": "Prefer `#cssdoc.include#` / `#cssdoc.exclude#`. This explicit list still works and takes precedence when non-empty."
        }
      }
    }
  },
  "activationEvents": [
    "onLanguage:css",
    "onLanguage:html",
    "onLanguage:javascriptreact",
    "onLanguage:typescriptreact"
  ],
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.125.0"
  }
}
