{
  "name": "@cssdoc/stylelint-plugin",
  "version": "0.4.1",
  "description": "Stylelint rules that check CSS doc-comment hygiene (undocumented modifiers/parts, deprecations, drift).",
  "keywords": [
    "css",
    "cssdoc",
    "documentation",
    "stylelint",
    "stylelint-plugin"
  ],
  "homepage": "https://cssdoc.dev",
  "bugs": "https://github.com/thedannywahl/cssdoc/issues",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thedannywahl/cssdoc.git",
    "directory": "plugins/stylelint"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test",
    "check": "vp check",
    "prepublishOnly": "vp run build",
    "publint": "publint"
  },
  "dependencies": {
    "@cssdoc/core": "workspace:*",
    "@cssdoc/lint-core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "postcss-html": "catalog:",
    "postcss-styled-syntax": "catalog:",
    "publint": "catalog:",
    "stylelint": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plus": "catalog:"
  },
  "peerDependencies": {
    "stylelint": ">=16"
  }
}
