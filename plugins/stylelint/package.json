{
  "name": "@cssdoc/stylelint-plugin",
  "version": "0.0.0",
  "description": "Stylelint rules that check CSS doc-comment hygiene (undocumented modifiers/parts, deprecations, drift).",
  "keywords": [
    "css",
    "cssdoc",
    "documentation",
    "stylelint",
    "stylelint-plugin"
  ],
  "license": "MIT",
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test",
    "check": "vp check",
    "prepublishOnly": "vp run build"
  },
  "dependencies": {
    "@cssdoc/core": "workspace:*",
    "@cssdoc/lint-core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "stylelint": "catalog:",
    "typescript": "catalog:",
    "vite": "npm:@voidzero-dev/vite-plus-core@0.2.2",
    "vite-plus": "catalog:"
  },
  "peerDependencies": {
    "stylelint": ">=16"
  }
}
