{
  "name": "@cssdoc/eslint-plugin",
  "version": "0.6.1",
  "description": "ESLint (@eslint/css) rules that check CSS doc-comment hygiene (undocumented modifiers/parts, deprecations, drift).",
  "keywords": [
    "css",
    "cssdoc",
    "documentation",
    "eslint",
    "eslint-plugin"
  ],
  "homepage": "https://cssdoc.dev",
  "bugs": "https://github.com/thedannywahl/cssdoc/issues",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thedannywahl/cssdoc.git",
    "directory": "plugins/eslint"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test",
    "check": "vp check",
    "prepublishOnly": "vp run build",
    "publint": "publint"
  },
  "dependencies": {
    "@cssdoc/config": "workspace:*",
    "@cssdoc/core": "workspace:*",
    "@cssdoc/embedded": "workspace:*",
    "@cssdoc/index": "workspace:*",
    "@cssdoc/lint-core": "workspace:*",
    "@cssdoc/providers": "workspace:*"
  },
  "devDependencies": {
    "@eslint/css": "catalog:",
    "@html-eslint/parser": "catalog:",
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "publint": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plus": "catalog:"
  },
  "peerDependencies": {
    "@eslint/css": ">=1",
    "@html-eslint/parser": ">=0.63",
    "eslint": ">=9"
  },
  "peerDependenciesMeta": {
    "@eslint/css": {
      "optional": true
    },
    "@html-eslint/parser": {
      "optional": true
    }
  }
}
