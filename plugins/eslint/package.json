{
  "name": "@cssdoc/eslint-plugin",
  "version": "0.0.0",
  "description": "ESLint (@eslint/css) rules that check CSS doc-comment hygiene (undocumented modifiers/parts, deprecations, drift).",
  "keywords": [
    "css",
    "cssdoc",
    "documentation",
    "eslint",
    "eslint-plugin"
  ],
  "license": "MIT",
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test",
    "check": "vp check",
    "prepublishOnly": "vp run build"
  },
  "dependencies": {
    "@cssdoc/core": "workspace:*",
    "@cssdoc/lint-core": "workspace:*"
  },
  "devDependencies": {
    "@eslint/css": "catalog:",
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "typescript": "catalog:",
    "vite": "npm:@voidzero-dev/vite-plus-core@0.2.2",
    "vite-plus": "catalog:"
  },
  "peerDependencies": {
    "@eslint/css": ">=1",
    "eslint": ">=9"
  }
}
