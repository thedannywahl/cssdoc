{
  "name": "@cssdoc/dtcg",
  "version": "0.3.2",
  "description": "Export cssdoc custom properties as W3C Design Tokens (DTCG): $value, $type, $description.",
  "keywords": [
    "css",
    "cssdoc",
    "design-tokens",
    "dtcg"
  ],
  "homepage": "https://cssdoc.dev",
  "bugs": "https://github.com/thedannywahl/cssdoc/issues",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thedannywahl/cssdoc.git",
    "directory": "generators/dtcg"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test",
    "check": "vp check",
    "prepublishOnly": "vp run build",
    "publint": "publint"
  },
  "dependencies": {
    "@cssdoc/core": "workspace:*",
    "@cssdoc/index": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "publint": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plus": "catalog:"
  }
}
